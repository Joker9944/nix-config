#!/usr/bin/env bash
# Query the pinned home-manager module options JSON.
#
# The JSON comes from the flake package `home-manager-docs-json`, which is a
# passthrough to `inputs.home-manager.packages.<system>.docs-json`. That means
# the schema (option names, types, defaults) reflects *exactly* the home-manager
# revision pinned in flake.lock — not upstream master, not whatever the model
# happens to remember.
#
# Requires: nix, jq. Must be run from a directory that can evaluate this flake
# (i.e., inside the nix-config repo).

set -euo pipefail

FLAKE_ATTR="${HM_DOC_FLAKE_ATTR:-.#home-manager-docs-json}"

usage() {
	cat <<'EOF'
hm-doc — query pinned home-manager options.json

Usage:
  hm-doc path                   Print the resolved options.json path.
  hm-doc get <option>           Full record for one option (type, default, example, description, declaration).
  hm-doc list <prefix>          All option keys starting with <prefix> (dot-separated).
  hm-doc search <keyword>       Options whose key or description contains <keyword> (case-insensitive).

Examples:
  hm-doc get programs.neovim.enable
  hm-doc list programs.gpg
  hm-doc search "ssh agent"

The pinned revision is whatever `flake.lock` says for the `home-manager` input.
EOF
}

resolve_json() {
	# The store path only changes when flake.lock changes, but `nix build`
	# re-evaluates the flake (~1s) on every call. Cache the resolved path and
	# skip the eval while the cache is newer than flake.lock and still points
	# at a readable options.json.
	local cache="${XDG_CACHE_HOME:-$HOME/.cache}/hm-doc/options-path"
	local lock="flake.lock"
	if [[ -r $cache && (! -e $lock || $cache -nt $lock) ]]; then
		local cached
		cached="$(<"$cache")"
		if [[ -r $cached ]]; then
			printf '%s\n' "$cached"
			return 0
		fi
	fi

	local out
	out="$(nix build --no-link --print-out-paths "$FLAKE_ATTR" 2>/dev/null)" || {
		echo "hm-doc: 'nix build $FLAKE_ATTR' failed. Are you inside the nix-config flake?" >&2
		return 1
	}
	local json="${out}/share/doc/home-manager/options.json"
	if [[ ! -r $json ]]; then
		echo "hm-doc: options.json not found at $json" >&2
		return 1
	fi
	mkdir -p "$(dirname "$cache")"
	printf '%s\n' "$json" >"$cache"
	printf '%s\n' "$json"
}

cmd="${1:-}"
case "$cmd" in
"" | -h | --help | help)
	usage
	;;
path)
	resolve_json
	;;
get)
	[[ $# -ge 2 ]] || {
		echo "hm-doc get: missing <option>" >&2
		usage
		exit 2
	}
	json="$(resolve_json)"
	result="$(jq --arg k "$2" '.[$k] // empty' "$json")"
	if [[ -z $result ]]; then
		echo "hm-doc: no option '$2' in $json" >&2
		echo "Try: hm-doc list <prefix>   or   hm-doc search <keyword>" >&2
		exit 1
	fi
	printf '%s\n' "$result"
	;;
list)
	[[ $# -ge 2 ]] || {
		echo "hm-doc list: missing <prefix>" >&2
		usage
		exit 2
	}
	json="$(resolve_json)"
	jq -r --arg p "$2" '
      keys[]
      | select(. == $p or startswith($p + "."))
    ' "$json"
	;;
search)
	[[ $# -ge 2 ]] || {
		echo "hm-doc search: missing <keyword>" >&2
		usage
		exit 2
	}
	json="$(resolve_json)"
	# Multi-word queries: every whitespace-separated token must appear
	# somewhere in the key or description (case-insensitive). This makes
	# `hm-doc search "gpg agent"` behave the way a human expects.
	jq -r --arg kw "$2" '
      ($kw | ascii_downcase | split(" ") | map(select(length > 0))) as $terms
      | to_entries
      | map(
          . as $entry
          | ((.key + " " + (.value.description // "")) | ascii_downcase) as $hay
          | select($terms | all(. as $t | $hay | contains($t)))
        )
      | .[]
      | "\(.key)\t\(.value.type // "")\t\((.value.description // "") | gsub("\n"; " ") | .[0:120])"
    ' "$json"
	;;
*)
	echo "hm-doc: unknown subcommand '$cmd'" >&2
	usage
	exit 2
	;;
esac
