{
	"dependencies": {
		"ags": "*",
		"gnim": "*"
	},
	"devDependencies": {
		"prettier": "^3.7.4",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2"
	},
	"prettier": {
		"semi": false,
		"tabWidth": 2
	},
	"scripts": {
		"run": "nix run .#ags -- run --gtk 4 --directory src",
		"types": "nix run .#ags -- types --update --ignore Gtk3 --ignore Astal3 --directory .",
		"inspect": "nix run .#ags -- inspect",
		"build": "nix build ."
	}
}
