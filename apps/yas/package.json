{
	"dependencies": {
		"ags": "*",
		"gnim": "*"
	},
	"devDependencies": {
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"prettier": "^3.7.4"
	},
	"prettier": {
		"plugins": [
			"@trivago/prettier-plugin-sort-imports"
		],
		"semi": false,
		"tabWidth": 2,
		"importOrder": [
			"^ags",
			"^gi://(.*)$",
			"^[./]"
		],
		"importOrderSeparation": true,
		"importOrderSortSpecifiers": true
	},
	"scripts": {
		"run": "nix run .#ags -- run --gtk 4 --directory src",
		"types": "nix run .#ags -- types --update --ignore Gtk3 --ignore Astal3 --directory .",
		"inspect": "nix run .#ags -- inspect",
		"build": "nix build ."
	}
}
